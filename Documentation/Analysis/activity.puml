    :Student requests current noise level;
    :requestNoiseData;
    :System returns noise level in decibels;
    label CheckNoiseLevel_end
}
split again
partition "CheckLightLevel" {
    label CheckLightLevel_start
    :Student requests current light level;
    :requestLightData;
    :System returns light intensity in lux;
