@startuml
' PlantUML generated by MODT
skinparam MessageAlign center
title Activity Diagram: StudyHelper
!include https://raw.githubusercontent.com/fredoslav2004/MinimalThemePUML/refs/heads/main/minimal-theme.puml
start
split
partition "Student" {
    label AssessStudyConditionsForStudySession_start
    :requestStudyConditionOverview;
    :sendStudyConditionOverview;
    label AssessStudyConditionsForStudySession_end
}
split again
partition "Student" {
    label RateStudySessionSuitability_start
    :submitStudySessionRating;
    :confirmRatingReceipt;
    label RateStudySessionSuitability_end
}
split again
partition "Student" {
    label ViewEnvironmentConditionHistory_start
    :requestEnvironmentConditionHistory;
    :sendEnvironmentConditionHistory;
    label ViewEnvironmentConditionHistory_end
}
split again
partition "Student" {
    :monitorActiveSessionConditions;
    label ReceiveStudentEnvironmentAlert_
    if (predictedStudyQuality == 1) then (yes)
      :skip;
    else (no)
    endif
    :triggerBuzzerAlert;
    label ReceiveStudentEnvironmentAlert_end
}
split again
partition "Student" {
    label StartStudySession_start
    :pressButtonToStartSession;
    :confirmSessionActive;
    label StartStudySession_end
}
split again
partition "Student" {
    label EndStudySession_start
    :pressButtonToEndSession;
    :confirmSessionEnded;
    label EndStudySession_end
}
split again
partition "Teacher" {
    label AssessConditionsForTeaching_start
    :requestTeachingConditionOverview;
    :sendTeachingConditionOverview;
    label AssessConditionsForTeaching_end
}
split again
partition "User" {
    label AuthenticateUser_start
    :submitCredentials;
    :confirmAuthentication;
    label AuthenticateUser_end
}
split again
partition "Student" {
    label ConnectDeviceToAccount_start
    :enterDeviceId;
    :confirmDeviceConnected;
    label ConnectDeviceToAccount_end
}
split again
partition "Student" {
    label ManageUserProfile_start
    :updateProfilePreferences;
    :confirmProfileUpdated;
    label ManageUserProfile_end
}
split again
partition "Student" {
    label ManageCalendarEvents_start
    :createCalendarEvent;
    :confirmEventCreated;
    label ManageCalendarEvents_end
}
endsplit
stop
@enduml
