@startuml
skinparam MessageAlign center
title Activity Diagram: StudyHelper Global Workflow
!include https://raw.githubusercontent.com/fredoslav2004/MinimalThemePUML/refs/heads/main/minimal-theme.puml

|User (Student/Teacher)|
start
:logIn;
|System|
:confirmAuthentication;

|User (Student/Teacher)|
if (Device connected?) then (no)
  :registerDevice;
  |System|
  :confirmDeviceRegistration;
else (yes)
endif

|User (Student/Teacher)|
:startStudySession;
|System|
:confirmSessionStart;

fork
  |System|
  repeat
    :monitorEnvironment;
    if (predictedStudyQuality == 1) then (yes)
      :alertStudent;
    else (no)
    endif
    :Wait for next reading;
  backward:Telemetry loop;
  repeat while (Session is active?) is (yes)
  ->no;
fork again
  |User (Student/Teacher)|
  repeat
    :requestStudyConditionOverview;
    |System|
    :sendStudyConditionOverview;
    |User (Student/Teacher)|
    :View dashboard;
    if (Submit rating during session?) then (yes)
      :rateStudySession;
      |System|
      :confirmRatingReceived;
    else (no)
    endif
  backward:Dashboard interaction;
  repeat while (Session is active?) is (yes)
  ->no;
end fork

|User (Student/Teacher)|
:endStudySession;
|System|
:confirmSessionEnd;

|User (Student/Teacher)|
if (Submit post-session rating?) then (yes)
  :rateStudySession;
  |System|
  :confirmRatingReceived;
else (no)
endif

|User (Student/Teacher)|
stop
@enduml
