.DS_Store

# Local environment/secrets
.env
.env.*
!.env.example
secrets.ini
!.ini.example

# Dependency/build output
__pycache__/
node_modules/
bin/
obj/
dist/
build/

# Root-level generated or misplaced artifacts
/Documentation.zip
/package-lock.json
/ratings.csv
/focus_dataset.csv
/environment_history.csv

# Generated ML artifacts
/MAL/models/*.pkl
/MAL/models/*.h5
/MAL/models/*.joblib

# Combined Data_6 csv dataset / run /Mal/scripts/combine_keti_data.py if needed
/MAL/data/interim/combined_keti_sensor_data.csv

# Generated unified ML dataset / run MAL/scripts/build_unified_environment_dataset.py
/MAL/data/processed/unified_environment_focus_dataset.csv
/MAL/data/processed/unified_environment_focus_dataset_report.csv

# Keep the manually trained production model so CI can run tests against it
# without retraining on every push.
!/MAL/models/rf_model.pkl

# gitignore processed data
/MAL/data/processed/*.csv

# Compiled reports and final hand-in archives
/Documentation/**/*.pdf
/Documentation/**/*.html
!/Documentation/guidelines/*.pdf
/*.zip
/build_staging/
