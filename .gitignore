.DS_Store

# Local environment/secrets
.env
.env.*
!.env.example
secrets.ini
!.ini.example

# Dependency/build output
__pycache__/
node_modules/
bin/
obj/
dist/
build/

# Root-level generated or misplaced artifacts
/Documentation.zip
/package-lock.json
/ratings.csv
/focus_dataset.csv
/environment_history.csv

# Generated ML artifacts
MAL/app/*.pkl
MAL/app/*.h5
# Keep the manually trained production model so CI can run tests against it
# without retraining on every push.
!MAL/app/rf_model.pkl
