@startuml
!theme plain
title MAL Data Flow & Pipeline Dependencies

' Layout and Spacing Settings
skinparam ranksep 40
skinparam nodesep 40
skinparam componentStyle rectangle
skinparam PackageBackgroundColor #FAFAFA
skinparam PackageBorderColor #DDDDDD

' Color scheme for components
skinparam component {
  BackgroundColor<<Script>> #E2F0D9
  BorderColor<<Script>> #385723
  BackgroundColor<<Notebook>> #FFF2CC
  BorderColor<<Notebook>> #D7970F
}
skinparam file {
  BackgroundColor #F5F5F5
  BorderColor #7F7F7F
}

' ==========================================================
' MOCK / DEVELOPMENT PIPELINE (LEFT COLUMN)
' ==========================================================
package "Mock / Development Data Pipeline" as mock_pipeline {
  
  package "Mock Raw Inputs" as mock_l1 {
    file "DATA_6/KETI/*/*.csv\n(Distributed Sensors)" as raw_keti
    file "DATA_7/HomeCoach_5min_*.csv\n(HomeCoach CSVs)" as raw_homecoach
    file "DATA_1/room_conditions.csv\n(Room Occupancy)" as raw_conditions
    file "DATA_8/.../1_room_measurements.csv\n(Smart Campus)" as raw_campus
  }

  package "Resampling & Preparation" as mock_l2 {
    component "resample_keti_data.py" as scr_resample <<Script>>
    component "prepare_homecoach.py" as scr_homecoach <<Script>>
    component "1_data_preparation.ipynb\n2_source_datasets_analysis.ipynb" as nb_prep <<Notebook>>
  }

  package "Interim Mock Data" as mock_l3 {
    file "keti_1min_resampled.csv" as int_keti
    file "HomeCoach_combined.csv" as int_homecoach
  }

  package "Merging & Unifying" as mock_l4 {
    component "build_unified_environment_dataset.py" as scr_build_unified <<Script>>
  }

  package "Unified Dataset" as mock_l5 {
    file "unified_environment_focus_dataset.csv" as proc_unified
  }

  package "Unified Dataset Cleaning" as mock_l6 {
    component "3_unified_dataset_analysis.ipynb" as nb_unified_analysis <<Notebook>>
  }

  package "Cleaned Unified Dataset" as mock_l7 {
    file "final_mock_dataset.csv" as proc_final_mock
  }

  package "Session Linearization" as mock_l8 {
    component "linearize_session_windows.py" as scr_linearize <<Script>>
    component "4_session_linearization.ipynb" as nb_session_lin <<Notebook>>
  }

  package "Linearized Intermediate" as mock_l9 {
    file "linearized_sessions_with_missing_targets.csv" as proc_missing
  }

  package "Target Imputation" as mock_l10 {
    component "fill_missing_targets.py" as scr_fill_targets <<Script>>
    component "5_fill_missing_targets.ipynb" as nb_fill_targets <<Notebook>>
  }

  package "Model-Ready Mock Dataset" as mock_l11 {
    file "linearized_session_windows.csv" as proc_session_windows
  }

  package "Training & Artifacts" as mock_l12 {
    component "train_model.py" as scr_train <<Script>>
    file "rf_model.pkl" as model_rf
  }
  
  ' Flow links for Mock Pipeline
  raw_keti --> scr_resample
  raw_homecoach --> scr_homecoach
  
  raw_keti ..> nb_prep : read-only
  raw_homecoach ..> nb_prep : read-only
  raw_conditions ..> nb_prep : read-only
  raw_campus ..> nb_prep : read-only
  
  scr_resample --> int_keti
  scr_homecoach --> int_homecoach
  
  int_keti --> scr_build_unified
  int_homecoach --> scr_build_unified
  raw_conditions --> scr_build_unified
  raw_campus --> scr_build_unified
  
  scr_build_unified --> proc_unified
  
  proc_unified --> nb_unified_analysis
  nb_unified_analysis ..> proc_final_mock #orange;line.dashed : [DUPLICATE WRITE]
  
  proc_final_mock --> scr_linearize
  proc_final_mock --> nb_session_lin
  
  scr_linearize --> proc_missing
  nb_session_lin ..> proc_missing #orange;line.dashed : [DUPLICATE WRITE]
  
  proc_missing --> scr_fill_targets
  proc_missing --> nb_fill_targets
  
  scr_fill_targets --> proc_session_windows
  nb_fill_targets ..> proc_session_windows #orange;line.dashed : [DUPLICATE WRITE]
  
  proc_session_windows --> scr_train
  scr_train --> model_rf
}

' ==========================================================
' REAL PRODUCTION PIPELINE (RIGHT COLUMN)
' ==========================================================
package "Real Production Pipeline" as real_pipeline {

  package "Production Data Source" as real_l1 {
    database "PostgreSQL DB\n(Real Production Data)" as db
  }

  package "Data Extraction" as real_l2 {
    component "extract_data.py" as scr_extract <<Script>>
  }

  package "Database Exports" as real_l3 {
    file "real/sensor_history.csv\nreal/sessions.csv" as real_raw
  }

  package "Real Linearization & Preprocessing" as real_l8 {
    component "linearize_and_glue.py" as scr_linearize_glue <<Script>>
    component "6_real_data_analysis_and_preprocessing.ipynb" as nb_real_prep <<Notebook>>
  }

  package "Real Model-Ready Dataset" as real_l11 {
    file "real/linearized_sessions_with_target.csv" as real_linearized
  }

  ' Flow links for Real Pipeline
  db --> scr_extract
  scr_extract --> real_raw
  
  real_raw --> scr_linearize_glue
  real_raw --> nb_real_prep
  
  scr_linearize_glue --> real_linearized
  nb_real_prep ..> real_linearized #orange;line.dashed : [DUPLICATE WRITE]
}

' Force layout side-by-side
mock_pipeline -[hidden]right-> real_pipeline

legend right
  |= Color / Line style |= Description |
  | <back:#E2F0D9>    </back> | Python Scripts (Production / Automated pipeline) |
  | <back:#FFF2CC>    </back> | Jupyter Notebooks (Exploration / Redundant logic) |
  | <back:#F5F5F5>    </back> | CSV Files |
  | #orange;line.dashed | **Duplicate Write**: Notebook writing to script output (conflict risk) |
endlegend

@enduml
