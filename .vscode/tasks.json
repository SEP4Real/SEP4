{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Academic HTML",
            "type": "shell",
            "command": "make -C Misc/AcademicTemplate html SRC='${file}'",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "detail": "Converts current Markdown file to HTML using the academic template."
        },
        {
            "label": "Build Academic PDF",
            "type": "shell",
            "command": "make -C Misc/AcademicTemplate pdf SRC='${file}'",
            "group": "build",
            "problemMatcher": [],
            "detail": "Converts current Markdown file to PDF using academic template."
        },
        {
            "label": "Run Everything (Docker Compose)",
            "type": "shell",
            "command": "docker compose up -d --build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": [],
            "detail": "Builds and starts Postgres and MAL API."
        }
    ]
}
