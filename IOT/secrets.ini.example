;  HOW TO USE:
;    1. Copy this file to `secrets.ini` (same folder — the
;       project root, next to platformio.ini).
;    2. Replace the placeholder values below with the real
;       WiFi credentials and server address.
;
;  NOTE: The quotes around string values must be escaped (\")
;        so they survive into the C preprocessor as real
;        string literals. Do not remove the backslashes.

[env:megaatmega2560]
build_flags =
    -DWIFI_SSID=\"your_ssid_here\"
    -DWIFI_PASSWORD=\"your_password_here\"
    -DSERVER_HOST=\"iot.sep4.eduardfekete.com\"
    -DSERVER_PORT=80
